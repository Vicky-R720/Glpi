-- Fichier de configuration SQLite pour les couleurs du Kanban

-- 1. Création de la table pour stocker les couleurs
CREATE TABLE IF NOT EXISTS kanban_colors (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    color_nouveau VARCHAR(20) NOT NULL DEFAULT '#1035ef',
    color_encours VARCHAR(20) NOT NULL DEFAULT '#bae1ff',
    color_termine VARCHAR(20) NOT NULL DEFAULT '#baffc9'
);

-- 2. Insertion des couleurs par défaut (avec gestion du conflit si l'ID 1 existe déjà)
INSERT INTO kanban_colors (id, color_nouveau, color_encours, color_termine) 
VALUES (1, '#0ae42b', '#bae1ff', '#baffc9')
ON CONFLICT(id) DO UPDATE SET 
    color_nouveau = excluded.color_nouveau,
    color_encours = excluded.color_encours,
    color_termine = excluded.color_termine;
