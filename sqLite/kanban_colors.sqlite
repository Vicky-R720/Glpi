-- Fichier de configuration SQLite pour les couleurs du Kanban

-- 1. Création de la table pour stocker les couleurs
CREATE TABLE IF NOT EXISTS kanban_colors (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    color_nouveau VARCHAR(20) NOT NULL DEFAULT '#1035ef',
    color_encours VARCHAR(20) NOT NULL DEFAULT '#bae1ff',
    color_termine VARCHAR(20) NOT NULL DEFAULT '#baffc9'
);

-- 2. Insertion des couleurs par défaut (avec gestion du conflit si l'ID 1 existe déjà)
INSERT INTO kanban_colors (id, color_nouveau, color_encours, color_termine) 
VALUES (1, '#0ae42b', '#bae1ff', '#baffc9')
ON CONFLICT(id) DO UPDATE SET 
    color_nouveau = excluded.color_nouveau,
    color_encours = excluded.color_encours,
    color_termine = excluded.color_termine;

CREATE TABLE IF NOT EXISTS status_translation (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    glpi_ids TEXT NOT NULL,    -- Stocké sous forme de texte, ex: '[1]' ou '[2, 3]'
    lang VARCHAR(5) NOT NULL,  -- Code de la langue: 'fr', 'en', 'es', etc.
    name VARCHAR(255) NOT NULL -- Le nom traduit
);

-- Insertion des données (Français)
INSERT OR IGNORE INTO status_translation (id, glpi_ids, lang, name) VALUES (1, '[1]', 'fr', 'Nouveau');
INSERT OR IGNORE INTO status_translation (id, glpi_ids, lang, name) VALUES (2, '[2, 3]', 'fr', 'En cours');
INSERT OR IGNORE INTO status_translation (id, glpi_ids, lang, name) VALUES (3, '[5]', 'fr', 'Terminé');

-- Insertion des données (Malgache)
INSERT OR IGNORE INTO status_translation (id, glpi_ids, lang, name) VALUES (4, '[1]', 'mlg', 'Vaovao');
INSERT OR IGNORE INTO status_translation (id, glpi_ids, lang, name) VALUES (5, '[2, 3]', 'mlg', 'Efa manao');
INSERT OR IGNORE INTO status_translation (id, glpi_ids, lang, name) VALUES (6, '[5]', 'mlg', 'Vita');
